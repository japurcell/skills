{
  "version": 1,
  "hooks": {
    "errorOccurred": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/log-error-occurred.sh"
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/log-pre-tooluse.sh"
      }
    ],
    "postToolUseFailure": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/log-tooluse-failure.sh"
      }
    ],
    "subagentStart": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/subagent-start.sh"
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/log-subagent-stop.sh"
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "echo -e '\\a'"
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/session-start.sh"
      }
    ]
  }
}
