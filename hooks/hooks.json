{
  "version": 1,
  "hooks": {
    "sessionEnd": [
      {
        "type": "command",
        "bash": "echo -e '\\a'",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "cd \"$HOME/.copilot/hooks\" && ./scripts/format.sh",
        "timeoutSec": 20
      }
    ]
  }
}
