{
  "version": 1,
  "hooks": {
    "sessionEnd": [
      {
        "type": "command",
        "bash": "echo -e '\\a'",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/session-start.sh"
      }
    ],
    "subagentStart": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/subagent-start.sh"
      }
    ]
  }
}
