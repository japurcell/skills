{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/adam/.gemini/hooks/scripts/session-start.sh"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/adam/.gemini/hooks/scripts/log-before-agent.sh"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/adam/.gemini/hooks/scripts/log-after-agent.sh"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "sequential": false,
        "hooks": [
          {
            "type": "command",
            "command": "/home/adam/.gemini/hooks/scripts/log-pre-tooluse.sh"
          },
          {
            "type": "command",
            "command": "rtk hook gemini"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/adam/.gemini/hooks/scripts/log-post-tooluse.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/adam/.gemini/hooks/scripts/log-notification.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/adam/.gemini/hooks/scripts/log-session-end.sh"
          }
        ]
      }
    ]
  }
}
