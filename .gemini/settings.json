{
  "context": {
    "fileName": ["AGENTS.md", "GEMINI.md"]
  },
  "experimental": {
    "autoMemory": true,
    "modelSteering": true
  },
  "general": {
    "enableNotifications": true,
    "plan": {
      "directory": ".agents/scratchpad"
    }
  },
  "ide": {
    "hasSeenNudge": true,
    "enabled": true
  },
  "model": {
    "name": "auto"
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "footer": {
      "hideContextPercentage": false,
      "showLabels": true,
      "items": [
        "workspace",
        "git-branch",
        "model-name",
        "context-used",
        "token-count",
        "quota"
      ]
    },
    "showMemoryUsage": true,
    "showModelInfoInChat": true,
    "showStatusInTitle": true
  },
  "agents": {
    "overrides": {
      "addy-code-reviewer": {
        "runConfig": {
          "maxTurns": 100,
          "maxTimeMinutes": 30
        }
      },
      "addy-security-auditor": {
        "runConfig": {
          "maxTurns": 100,
          "maxTimeMinutes": 30
        }
      },
      "addy-test-engineer": {
        "runConfig": {
          "maxTurns": 100,
          "maxTimeMinutes": 30
        }
      },
      "browser_agent": {
        "enabled": true
      },
      "code-architect": {
        "runConfig": {
          "maxTurns": 100,
          "maxTimeMinutes": 30
        }
      },
      "code-explorer": {
        "runConfig": {
          "maxTurns": 100,
          "maxTimeMinutes": 30
        }
      },
      "code-reviewer": {
        "runConfig": {
          "maxTurns": 100,
          "maxTimeMinutes": 30
        }
      },
      "code-simplifier": {
        "runConfig": {
          "maxTurns": 100,
          "maxTimeMinutes": 30
        }
      },
      "codebase_investigator": {
        "runConfig": {
          "maxTurns": 50,
          "maxTimeMinutes": 30
        }
      },
      "generalist": {
        "runConfig": {
          "maxTurns": 50,
          "maxTimeMinutes": 30
        }
      },
      "ui-auditor": {
        "runConfig": {
          "maxTurns": 100,
          "maxTimeMinutes": 30
        }
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/log-session-start.sh"
          },
          {
            "name": "skill-context-injector",
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/skill-context-injector.sh",
            "description": "Loads required skill files and injects them as context before each agent turn."
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/log-after-agent.sh"
          },
          {
            "name": "hedge-detector",
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/hedge-detector.sh",
            "description": "Rejects over-certain final answers that omit explicit evidence and uncertainty sections.",
            "timeout": 10000
          },
          {
            "name": "pride-check",
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/pride-check.sh",
            "description": "Rejects changed-code final answers that omit the required Pride Check craft self-audit section.",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "tool-guard",
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/tool-guard.sh",
            "description": "Blocks dangerous Gemini tool invocations using same policy patterns as Copilot tool-guard."
          }
        ]
      },
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/rtk-hook-gemini.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/log-notification.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/log-session-end.sh"
          },
          {
            "name": "scan-secrets",
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/scan-secrets.sh",
            "description": "Scans modified files for potential secrets and logs env-file access during Gemini session shutdown."
          }
        ]
      }
    ]
  }
}
