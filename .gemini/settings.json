{
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md"
    ]
  },
  "experimental": {
    "modelSteering": true
  },
  "general": {
    "enableNotifications": true,
    "plan": {
      "directory": ".agents/scratchpad"
    }
  },
  "ide": {
    "hasSeenNudge": true,
    "enabled": true
  },
  "model": {
    "name": "auto"
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "footer": {
      "hideContextPercentage": false,
      "showLabels": true,
      "items": [
        "workspace",
        "git-branch",
        "model-name",
        "context-used",
        "token-count",
        "quota"
      ]
    },
    "showMemoryUsage": true,
    "showModelInfoInChat": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/log-session-start.sh"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "skill-context-injector",
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/skill-context-injector.sh",
            "description": "Loads required skill files and injects them as context before each agent turn."
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/log-after-agent.sh"
          },
          {
            "name": "hedge-detector",
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/hedge-detector.sh",
            "description": "Rejects over-certain final answers that omit explicit evidence and uncertainty sections.",
            "timeout": 10000
          },
          {
            "name": "pride-check",
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/pride-check.sh",
            "description": "Rejects changed-code final answers that omit the required Pride Check craft self-audit section.",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "tool-guard",
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/tool-guard.sh",
            "description": "Blocks dangerous Gemini tool invocations using same policy patterns as Copilot tool-guard."
          }
        ]
      },
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/rtk-hook-gemini.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/log-notification.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/hooks/scripts/log-session-end.sh"
          }
        ]
      }
    ]
  }
}
