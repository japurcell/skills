{
  "version": 1,
  "hooks": {
    "agentStop": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/log-agent-stop.sh"
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/log-error-occurred.sh"
      }
    ],
    "notification": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/log-notification.sh"
      }
    ],
    "postToolUseFailure": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/log-tooluse-failure.sh"
      }
    ],
    "subagentStart": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/load-required-skills.sh"
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/log-subagent-stop.sh"
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "echo -e '\\a'"
      },
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/log-session-end.sh"
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/load-required-skills.sh"
      }
    ]
  }
}
