{
  "skill_name": "feature-dev",
  "evals": [
    {
      "id": 0,
      "prompt": "You're in a skills repository. A user says: \"Tighten the feature-dev skill so it only triggers for medium-to-large feature work, and add a short 'When not to use this skill' section. Inspect the current skill and tell me exactly how you'd make the change. Only ask questions if something is truly blocking.\"",
      "expected_output": "A calibrated implementation plan for a small, concrete skill change that avoids unnecessary blocking questions and scales the process to the task.",
      "files": [],
      "expectations": [
        "References the existing feature-dev skill directly rather than answering generically.",
        "Avoids asking blocking clarifying questions for this well-specified task.",
        "Proposes concrete description and body changes, including a scoped 'When not to use this skill' addition.",
        "Scales the workflow to the task instead of insisting on a full multi-phase approval process."
      ]
    },
    {
      "id": 1,
      "prompt": "A user says: \"I want the feature-dev skill to work better for product-sized work in unfamiliar repos. Figure out what should change, what questions you'd ask me, and what approach you'd recommend before editing anything.\" Use this repository as context.",
      "expected_output": "A repo-aware discovery response that separates findings, targeted clarifying questions, and a recommended direction before editing.",
      "files": [],
      "expectations": [
        "Uses findings from the current repository and current feature-dev skill rather than generic advice.",
        "Asks targeted clarifying questions that are grounded in concrete risks or ambiguities.",
        "Caps clarifying questions to a small, prioritized set rather than turning discovery into a broad interview.",
        "Chooses a calibrated standard-level process for this request instead of defaulting to a deep planning workflow.",
        "Separates current understanding, open questions, and a recommended approach.",
        "Explains why the proposed changes would help with unfamiliar repositories."
      ]
    },
    {
      "id": 2,
      "prompt": "Use the feature-dev workflow for this request and stop before implementation: 'Prepare a handoff for adding stricter handoff-policy enforcement to feature-dev so another agent can implement next.' In your run, actually create the handoff artifact file your workflow requires (not just a proposal) and provide artifact status with the exact path.",
      "expected_output": "A repo-aware handoff result that actually creates a reusable artifact file with concrete implementation guidance, not just prose about one.",
      "files": [],
      "expectations": [
        "Looks for relevant patterns elsewhere in this repository instead of inventing the design in isolation.",
        "Creates a concrete file-backed handoff artifact at a path matching the workflow's handoff contract.",
        "The artifact content follows a reusable template shape and includes implementation slices, file-level map, and validation plan.",
        "Artifact metadata fields are concretely filled (no placeholder bracket values) for status, track, and next step.",
        "Each referenced file in Relevant Findings includes why that file matters.",
        "Open questions are tightly bounded to truly blocking items and include risk framing.",
        "Provides artifact status in the response with the exact artifact path.",
        "Includes rationale or trade-offs for the proposed design."
      ]
    }
  ]
}
